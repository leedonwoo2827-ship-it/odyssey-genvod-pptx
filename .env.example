# 영상공방 (VOD Studio) — Environment Configuration
# Copy this file to .env and fill in your values. (모두 선택 사항 — 비워도 동작)

# ============================================================
# LLM Configuration
# ============================================================

# Primary LLM host (default: localhost)
LLM_HOST=localhost

# Additional LLM hosts, comma-separated (for model discovery)
# Use hostnames/IPs only; Odysseus scans common serve ports, including Ollama's 11434.
# LLM_HOSTS=llm-host.local,backup-llm.local

# (선택) 로컬 임베딩/모델 엔드포인트 — 영상공방은 기본적으로 로컬 FastEmbed를 쓰므로 불필요.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LM_STUDIO_URL=http://localhost:1234

# OpenAI API key (only needed if using OpenAI models).
# Do not commit real keys. Keep this commented until needed.
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# Database
# ============================================================

# SQLite database path (default: sqlite:///./data/app.db)
# DATABASE_URL=sqlite:///./data/app.db

# ============================================================
# Auth & Security
# ============================================================

# Enable authentication.
# 로컬 단독 사용에서는 false 로 두면 시작 시 /login 강제가 없어 /vodstudio 로 바로 들어갑니다.
# 구글 로그인은 화면의 ⚙ 설정에서 '선택적으로' 할 수 있습니다.
# 외부에 노출하거나 다중 사용자면 반드시 true 로 두세요.
AUTH_ENABLED=false

# 포트 변경(다른 앱이 7000을 쓰면). run.bat 의 PORT 도 함께 바꾸세요.
# APP_PORT=7000

# Mark session cookies Secure. Set true when served through HTTPS
# by a trusted reverse proxy or private access gateway.
# SECURE_COOKIES=true

# Optional: pre-seed the first admin password during setup.
# Do not commit a real password.
# ODYSSEUS_ADMIN_PASSWORD=change_me_before_first_boot

# CORS allowed origins (default: localhost-only; restrict to your public origin in production)
# ALLOWED_ORIGINS=http://localhost:7000,http://localhost:8000

# ------------------------------------------------------------
# Google OAuth — "Sign in with Google"
# ------------------------------------------------------------
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console
# (APIs & Services > Credentials). Add this Authorized redirect URI exactly:
#   http://127.0.0.1:7000/api/auth/google/callback
# Both CLIENT_ID and CLIENT_SECRET must be set for the button to appear.
# GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=xxxxxxxx
# Public base URL used to build the callback (default http://127.0.0.1:7000).
# Must match the host:port you open in the browser and the redirect URI above.
# OAUTH_REDIRECT_BASE=http://127.0.0.1:7000
# Optional access control. If either is set, only matching emails may sign in.
# The first account ever created always becomes admin.
# GOOGLE_OAUTH_ALLOWED_EMAILS=you@example.com,teammate@example.com
# GOOGLE_OAUTH_ALLOWED_DOMAIN=ubion.co.kr

# ============================================================
# 대본 생성 LLM 공급자 (API 키 없음 · CLI 계정 로그인)
# 만료되는 gemini CLI 대신 codex(OpenAI/ChatGPT) + agy(Antigravity→Gemini/Google) 토글.
# ============================================================
# 기본 활성 공급자: codex | agy  (화면 토글로 전환되며 data/llm_provider.json에 저장)
# LLM_PROVIDER=codex
# Codex CLI 실행 파일 경로 override (PATH에 있으면 불필요). `codex login` 으로 ChatGPT 로그인.
# CODEX_BIN=codex
# CODEX_MODEL=            # 비우면 codex 기본 모델
# CODEX_EXEC_TIMEOUT=300
# Antigravity CLI(agy) override. `agy` 실행으로 Google 로그인.
# AGY_BIN=agy
# AGY_MODEL=              # 예: gemini-3-pro (비우면 화면 선택/agy 기본)
# AGY_PRINT_TIMEOUT=300

# ============================================================
# 로컬 CPU TTS (VoiceWright / Supertonic-3, ONNX · 클라우드 없음)
# ============================================================
# VOICEWRIGHT_USE_GPU=auto         # auto | 1 | 0
# VOICEWRIGHT_DEFAULT_SPEED=1.00
# VOICEWRIGHT_TOTAL_STEP=8         # 디퓨전 스텝(품질/속도 트레이드오프)
# VOICEWRIGHT_ASSETS_DIR=          # 기본: <repo>/assets (onnx 모델 + voice_styles)
# VOICEWRIGHT_VOICE_MAP=           # 기본: <repo>/config/voice_map.yaml
# VOICEWRIGHT_PRONUNCIATION_MAP=   # 기본: <repo>/config/pronunciation_map.yaml

# ============================================================
# RAG / Embeddings (영상공방은 로컬 FastEmbed/ONNX 사용 — 외부 서비스 불필요)
# ============================================================

# 로컬 임베딩 모델 (첫 실행 시 ~50MB 다운로드, 이후 캐시)
# FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# FASTEMBED_CACHE_PATH=  # 기본: ~/.cache/fastembed

# ============================================================
# Misc
# ============================================================

# Cleanup interval in hours (default: 24)
# CLEANUP_INTERVAL_HOURS=24

# In-process email pollers (default: on). Set to 0 if you're driving
# polling from cron / systemd via `scripts/odysseus-mail poll-scheduled`
# and `scripts/odysseus-mail poll-summary`, otherwise both schedulers
# race on the same SQLite.
# ODYSSEUS_INPROCESS_POLLERS=1

# In-process scheduled-task runner (default: on). Set to 0 to let an
# external driver fire scheduled tasks. Calendar reminders are
# frontend-driven (polling /api/notes from the browser) so no gate is
# needed there.
# ODYSSEUS_INPROCESS_TASKS=1

# Host used by the built-in "run_script" scheduled-task action.
# ODYSSEUS_SCRIPT_HOST=localhost
